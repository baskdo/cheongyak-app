import { NextResponse } from "next/server"

type ApiRow = {
  HOUSE_MANAGE_NO?: string
  PBLANC_NO?: string
  HOUSE_NM?: string
  HOUSE_TY?: string
  SUPLY_HSHLDCO?: string | number
  REQ_CNT?: string | number
  SUBSCRPT_RANK_CODE?: string
  RESIDE_SECD?: string
}

type TypeAgg = {
  type: string
  supply: number
  special: number
  rank1: number
}

type HouseAgg = {
  pblancNo: string
  houseName: string
  region: string
  types: Record<string, TypeAgg>
}

function regionFromName(name: string): string {
  const t = name || ""

  if (t.includes("서울")) return "서울"
  if (t.includes("경기")) return "경기"
  if (t.includes("인천")) return "인천"
  if (t.includes("부산")) return "부산"
  if (t.includes("대구")) return "대구"
  if (t.includes("광주")) return "광주"
  if (t.includes("대전")) return "대전"
  if (t.includes("울산")) return "울산"
  if (t.includes("세종")) return "세종"
  if (t.includes("강원")) return "강원"
  if (t.includes("충북")) return "충북"
  if (t.includes("충남")) return "충남"
  if (t.includes("전북")) return "전북"
  if (t.includes("전남")) return "전남"
  if (t.includes("경북")) return "경북"
  if (t.includes("경남")) return "경남"
  if (t.includes("제주")) return "제주"

  return "기타"
}

function parseType(houseTy?: string): string {
  if (!houseTy) return ""
  const n = houseTy.split(".")[0]
  return String(parseInt(n, 10))
}

async function fetchAll(): Promise<ApiRow[]> {
  const key = process.env.ODCLOUD_API_KEY
  if (!key) throw new Error("ODCLOUD_API_KEY not set")

  const perPage = 1000
  let page = 1
  let done = false
  const rows: ApiRow[] = []

  while (!done) {
    const url =
      "https://api.odcloud.kr/api/ApplyhomeInfoCmpetRtSvc/v1/getAPTLttotPblancCmpet" +
      `?serviceKey=${encodeURIComponent(key)}` +
      `&page=${page}&perPage=${perPage}&returnType=JSON`

    const res = await fetch(url, { cache: "no-store" })
    if (!res.ok) throw new Error("API fetch failed")

    const json = await res.json()

    const data: ApiRow[] = json.data || []
    rows.push(...data)

    if (data.length < perPage) done = true
    else page++
  }

  return rows
}

export async function GET() {
  try {
    const rows = await fetchAll()

    const houses: Record<string, HouseAgg> = {}

    for (const r of rows) {
      const key = r.PBLANC_NO || r.HOUSE_MANAGE_NO
      if (!key) continue

      if (!houses[key]) {
        houses[key] = {
          pblancNo: key,
          houseName: r.HOUSE_NM || "",
          region: regionFromName(r.HOUSE_NM || ""),
          types: {}
        }
      }

      const type = parseType(r.HOUSE_TY)
      if (!type) continue

      if (!houses[key].types[type]) {
        houses[key].types[type] = {
          type,
          supply: 0,
          special: 0,
          rank1: 0
        }
      }

      const agg = houses[key].types[type]

      const supply = Number(r.SUPLY_HSHLDCO || 0)
      const req = Number(r.REQ_CNT || 0)
      const rank = r.SUBSCRPT_RANK_CODE

      agg.supply = Math.max(agg.supply, supply)

      if (rank === "01") {
        agg.rank1 += req
      }

      if (rank === "00") {
        agg.special += req
      }
    }

    const items = Object.values(houses).map(h => ({
      pblancNo: h.pblancNo,
      houseName: h.houseName,
      region: h.region,
      types: Object.values(h.types).sort(
        (a, b) => Number(a.type) - Number(b.type)
      )
    }))

    return NextResponse.json({
      total: items.length,
      items
    })
  } catch (e) {
    return NextResponse.json({
      total: 0,
      items: [],
      error: String(e)
    })
  }
}